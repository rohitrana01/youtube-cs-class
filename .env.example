# Copy this to .env and fill in your values

# Anthropic Claude API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# YouTube OAuth credentials (from Google Cloud Console)
YOUTUBE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxx
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxx

# Optional settings
CHANNEL_NAME=LearnCS Daily
TTS_VOICE=en-US-AriaNeural
VIDEO_PRIVACY=public
